# Copy to .env (or export in your shell) before running the model layer.
# .env is git-ignored; .env.example is committed.

# Django (apps/api/) — see backend/settings.py
# SECRET_KEY: required in production. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
# If unset, settings.py falls back to an insecure dev-only placeholder.
# SECRET_KEY=
# DEBUG=True
# ARTIFACTS_PATH=/absolute/path/to/pipeline/artifacts

# EIA API key for refreshing pipeline/artifacts/eia_gas_scalars.json.
# Free registration: https://www.eia.gov/opendata/register.php
# Consumed by models.matching.eia_gas and scripts/refresh_cpi.py.
# When unset, the model layer gracefully falls back to the last cached
# scalars; if there is no cache, the gas-specific spatial correction
# silently defaults to 1.0 per state.
EIA_API_KEY=
